{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "group:allNonMajor"
    ],
    "timezone": "Europe/Berlin",
    "minimumReleaseAge": "2 days",
    "schedule": [
        "* 0-4 * * 4"
    ],
    "rangeStrategy": "pin",
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
            "* 0-4 * * 5"
        ]
    }
}